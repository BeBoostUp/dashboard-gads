# Copia este archivo como .env y rellena los valores reales.
# No subas .env a GitHub.

GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=

# MCC desde el que tu usuario OAuth opera. Sin guiones.
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# MCC concreto dentro del tuyo que quieres usar como raiz del dashboard. Sin guiones.
GOOGLE_ADS_TARGET_MCC_ID=

# Opcional. Ahora se usa v22 porque es la version actual en la documentacion REST consultada.
GOOGLE_ADS_API_VERSION=v22

# Limite por cliente para keywords, terminos y assets. Mantiene la carga rapida.
GOOGLE_ADS_PER_ACCOUNT_LIMIT=50

# Refresco automatico del servidor. 360 = cada 6 horas.
GOOGLE_ADS_REFRESH_INTERVAL_MINUTES=360

# En online puedes poner true para que el servidor prepare datos al arrancar.
GOOGLE_ADS_AUTO_PRIME=false

# En local puedes dejar 127.0.0.1. Vercel no necesita HOST.
HOST=127.0.0.1

# Opcional para proteger llamadas manuales al cron de refresco en Vercel.
CRON_SECRET=
